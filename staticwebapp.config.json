{
  "routes": [
    {
      "route": "/dashboard",
      "rewrite": "/dashboard/index.html"
    },
    {
      "route": "/sign*",
      "rewrite": "/sign.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.css", "*.js", "*.png", "*.jpg", "*.ico", "*.json"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
