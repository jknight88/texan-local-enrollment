{
  "routes": [
    {
      "route": "/*",
      "rewrite": "/index.html"
    },
    {
      "route": "/dashboard/*",
      "rewrite": "/dashboard/index.html"
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  }
}
