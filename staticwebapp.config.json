{
  "routes": [
    { "route": "/",             "rewrite": "/index.html" },
    { "route": "/dashboard",    "rewrite": "/dashboard/index.html" },
    { "route": "/sign*",        "rewrite": "/sign.html" },
    { "route": "/inperson",     "rewrite": "/inperson.html" },
    { "route": "/countersign*", "rewrite": "/countersign.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.{css,scss,js,png,gif,ico,jpg,svg,json,woff,woff2,ttf}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": { "apiRuntime": "node:22" }
}
